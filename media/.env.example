# General Service Info
VERSION=1.0.0
MODE=debug
SERVICE_NAME=media
HTTP_PORT=8086
MIGRATION_SOURCE=migrations

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production

# APM Configuration (optional - leave empty if not using)
APM_SERVICE_NAME=
APM_SERVER_URL=
APM_SECRET_TOKEN=
APM_ENVIRONMENT=development

# RabbitMQ Configuration
RABBITMQ_URL=amqp://admin:admin@localhost:5672
RMQ_RECONNECT_DELAY=5
RMQ_RETRY_INTERVAL=600
RMQ_QUEUE_PREFIX=media-dev

# Database Configuration
BGCE_DB_DSN=postgresql://postgres:root@localhost:5432/bgce_archive?sslmode=disable
BGCE_DB_DRIVER=postgres

# MinIO/S3 Configuration
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=bgce-media
MINIO_REGION=us-east-1

# CDN Configuration (optional)
CDN_BASE_URL=http://localhost:9000

# Upload Configuration
MAX_UPLOAD_SIZE_MB=50
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/webm,video/ogg
ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# Image Processing
ENABLE_IMAGE_OPTIMIZATION=true
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=300
MAX_IMAGE_WIDTH=2048
MAX_IMAGE_HEIGHT=2048





