# General Service Info
VERSION=1.0.0
MODE=debug
SERVICE_NAME=axon
HTTP_PORT=8088
MIGRATION_SOURCE=migrations

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production

# APM Configuration (optional - leave empty if not using)
APM_SERVICE_NAME=
APM_SERVER_URL=
APM_SECRET_TOKEN=
APM_ENVIRONMENT=development

# RabbitMQ Configuration
RABBITMQ_URL=amqp://admin:admin@127.0.0.1:5672
RMQ_RECONNECT_DELAY=5
RMQ_RETRY_INTERVAL=600
RMQ_QUEUE_PREFIX=axon-dev
RMQ_EXCHANGE_NAME=bgce.events
RMQ_EXCHANGE_TYPE=topic
RMQ_QUEUE_NAME=axon-dev.notifications

# Redis Configuration
READ_REDIS_URL=redis://127.0.0.1:6379
WRITE_REDIS_URL=redis://127.0.0.1:6379
ENABLE_REDIS_TLS_MODE=false

# Database Configuration
BGCE_DB_DSN=postgres://postgres:root@127.0.0.1:5432/cortex_db?sslmode=disable
BGCE_DB_DRIVER=postgres

# Email Configuration
EMAIL_PROVIDER=smtp

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_AUTH_METHOD=plain
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=BGCE Archive

# Notification Settings
DIGEST_ENABLED=true
DIGEST_SCHEDULE=weekly
BATCH_EMAIL_SIZE=100
BATCH_EMAIL_INTERVAL=60